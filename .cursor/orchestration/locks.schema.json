{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DE orchestration locks",
  "type": "object",
  "required": ["version", "locks"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "locks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["root", "branch", "owner"],
        "properties": {
          "root": { "type": "string" },
          "branch": { "type": "string" },
          "owner": { "type": "string" },
          "ticket": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
