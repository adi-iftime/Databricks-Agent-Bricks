    {
      "pattern": "(?i)(Authorization:\\s*Bearer\\s+[A-Za-z0-9._-]{20,})",
      "message": "Bearer token in source"
    },
    {
      "pattern": "\\bdapi[a-f0-9]{20,}\\b",
      "message": "Databricks personal access token shape (dapi...)"
    },
    {
      "pattern": "\\bdkea[a-f0-9]{20,}\\b",
      "message": "Databricks OAuth token shape (dkea...)"
    },
    {
      "pattern": "(?i)(password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"\\s]{8,}['\"]",
      "message": "Inline password assignment"
    }
  ]
